# REQUIRED — Claude API key
ANTHROPIC_API_KEY=sk-ant-...

# Models
CLAUDE_DEBATE_MODEL=claude-opus-4-7
CLAUDE_PARSE_MODEL=claude-haiku-4-5-20251001

# OPTIONAL data providers (all have free tiers)
FINNHUB_API_KEY=
NEWSAPI_API_KEY=
FRED_API_KEY=

# Runtime
DATABASE_URL=sqlite+aiosqlite:///./investment_agent.db
CACHE_DIR=./data_cache
KNOWLEDGE_BASE_DIR=../knowledge_base
PINE_SCRIPT_DIR=../pine_scripts

# Scheduler
DAILY_SCAN_CRON=30 8 * * MON-FRI   # 08:30 local, weekdays
WEEKLY_LEARNING_CRON=0 18 * * SUN
MONTHLY_SKILLS_CRON=0 19 1 * *

# Debate config
DEBATE_ROUNDS=2
DEBATE_ALLOW_DISSENT=true

# CORS
FRONTEND_ORIGIN=http://localhost:5173
